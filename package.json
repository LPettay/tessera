{
  "name": "tessera-engine",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript framework for layered 2D voxel scenes. Pluggable renderer (SVG / Canvas2D / WebGL2), dynamic entities, page-citizenship defaults.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "check": "bun run scripts/check.ts",
    "check:agents": "bun run scripts/check.ts --only=presence,freshness",
    "check:fs": "bun run scripts/check.ts --only=forbidden",
    "typecheck": "bunx tsc --noEmit",
    "agents:stamp": "bun run scripts/stamp.ts",
    "agents:stamp-all": "bun run scripts/stamp.ts --all",
    "agents:stale": "bun run scripts/check.ts --only=freshness --verbose",
    "wt:add": "bun run scripts/worktree.ts add",
    "wt:list": "bun run scripts/worktree.ts list",
    "wt:remove": "bun run scripts/worktree.ts remove",
    "dev:mug": "bun run examples/mug-svg/dev.ts",
    "build:mug": "bun run examples/mug-svg/build.ts",
    "dev:menu": "bun run examples/menu-svg/dev.ts",
    "build:menu": "bun run examples/menu-svg/build.ts",
    "dev:inventory": "bun run examples/inventory-svg/dev.ts",
    "build:inventory": "bun run examples/inventory-svg/build.ts",
    "dev:landing": "bun run examples/landing-svg/dev.ts",
    "build:landing": "bun run examples/landing-svg/build.ts",
    "dev:rhythm": "bun run examples/rhythm-svg/dev.ts",
    "build:rhythm": "bun run examples/rhythm-svg/build.ts",
    "build:examples": "bun run build:mug && bun run build:menu && bun run build:inventory && bun run build:landing && bun run build:rhythm",
    "prepare": "bunx lefthook install || true"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^1.7.0",
    "typescript": "^5.5.0"
  }
}
